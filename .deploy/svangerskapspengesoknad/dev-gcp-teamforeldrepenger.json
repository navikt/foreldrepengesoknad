{
    "app": "svangerskapspengesoknad",
    "autentisering": true,
    "minReplicas": "1",
    "maxReplicas": "1",
    "limits": {
        "cpu": "200m",
        "mem": "256Mi"
    },
    "requests": {
        "cpu": "15m",
        "mem": "160Mi"
    },
    "redirect": {
        "host": "svangerskapspengesoknad.intern.dev.nav.no",
        "ingressClassName": "nais-ingress"
    },
    "env": {
        "PUBLIC_PATH": "/svangerskapspenger/soknad",
        "INNSYN": "https://www.intern.dev.nav.no/foreldrepenger/oversikt",
        "LOG_VALIDATION": false,
        "ENV": "dev",
        "VITE_MODE_PORT": "9112"
    },
    "ingresses": [
        "https://www.intern.dev.nav.no/svangerskapspenger/soknad",
        "https://www.ekstern.dev.nav.no/svangerskapspenger/soknad"
    ]
}
