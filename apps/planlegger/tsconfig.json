        "../../packages/ny-uttaksplan/src/utils/HvemPlanleggerUtils.test.ts",
        "../../packages/ny-uttaksplan/src/utils/hvemHarRettUtils.ts",
        "../../packages/ny-uttaksplan/src/utils/barnetUtils.ts",
        "../../packages/ny-uttaksplan/src/utils/umamiUtils.ts"
    ],
    "exclude": ["node_modules"]
}
