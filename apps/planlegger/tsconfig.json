{
    "extends": "@navikt/fp-config-typescript/tsconfig.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "paths": {
            "styles/*": ["./src/styles/*"],
            "intl/*": ["./src/intl/*"],
            "types/*": ["./src/types/*"],
            "appData/*": ["./src/app-data/*"],
            "utils/*": ["./src/utils/*"],
            "steps/*": ["./src/steps/*"],
            "components/*": ["./src/components/*"]
        },
        "types": ["@testing-library/jest-dom", "vitest/globals", "vite/client"]
    },
    "include": ["src", "mock-api", "vitest", "../../@types"],
    "exclude": ["node_modules"]
}
