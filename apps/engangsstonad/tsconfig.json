{
    "extends": "@navikt/fp-config-typescript/tsconfig.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "paths": {
            "styles/*": ["./src/styles/*"],
            "types/*": ["./src/types/*"],
            "appData/*": ["./src/app-data/*"]
        },
        "types": ["node", "@testing-library/jest-dom", "vitest/globals", "vite/client"]
    },
    "include": ["src", "mock-api", "vitest", "../../@types"],
    "exclude": ["node_modules"]
}
