{
    "extends": "@navikt/fp-config-typescript/tsconfig.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "paths": {
            "appData/*": ["./src/app-data/*"],
            "pages/*": ["./src/pages/*"],
            "steps/*": ["./src/steps/*"],
            "utils/*": ["./src/utils/*"],
            "api/*": ["./src/api/*"],
            "types/*": ["./src/types/*"],
            "storybookData/*": ["./.storybook/storybook-data/*"]
        },
        "types": ["vite/client", "@testing-library/jest-dom", "vitest/globals"]
    },
    "include": ["src", "mock-api", "vitest", "../../@types"],
    "exclude": ["node_modules"]
}
