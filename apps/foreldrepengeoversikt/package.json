{
    "name": "foreldrepengeoversikt",
    "version": "1.0.0",
    "type": "module",
    "description": "NAV foreldrepengeoversikt",
    "repository": "https://github.com/navikt/foreldrepengeoversikt",
    "scripts": {
        "build": "vite build",
        "build:storybook": "storybook build -o .storybook-static-build",
        "test": "vitest --project=jsdom --watch=false",
        "test:browser": "vitest --project=browser",
        "eslint": "eslint \"./src/**/*.{js,ts,tsx}\"",
        "eslint:fix": "eslint --quiet --fix  \"./src/**/*.{js,ts,tsx}\"",
        "prettier:fix": "prettier --write src",
        "tsc": "tsc --noEmit",
        "tsc:watch": "tsc --noEmit --watch",
        "dev:vite": "vite",
        "dev:mock": "node --loader ts-node/esm ./mock-api/mock-api-server.ts",
        "dev:lokal": "node ./dev-server.cjs",
        "storybook": "storybook dev --quiet -p 7003",
        "clean": "rm -rf ./dist ./node_modules ./.turbo ./.storybook-static-build"
    },
    "author": "NAV",
    "license": "MIT",
    "dependencies": {
        "@navikt/aksel-icons": "catalog:",
        "@navikt/ds-css": "catalog:",
        "@navikt/ds-react": "catalog:",
        "@navikt/ds-tailwind": "catalog:",
        "@navikt/fp-app-shell": "workspace:*",
        "@navikt/fp-constants": "workspace:*",
        "@navikt/fp-filopplaster": "workspace:*",
        "@navikt/fp-form-hooks": "workspace:*",
        "@navikt/fp-observability": "workspace:*",
        "@navikt/fp-types": "workspace:*",
        "@navikt/fp-ui": "workspace:*",
        "@navikt/fp-utils": "workspace:*",
        "@navikt/fp-uttaksplan": "workspace:*",
        "@navikt/fp-validation": "workspace:*",
        "@navikt/nav-dekoratoren-moduler": "catalog:",
        "@sentry/vite-plugin": "catalog:",
        "@tanstack/react-query": "catalog:",
        "classnames": "catalog:",
        "dayjs": "catalog:",
        "jotai": "2.20.1",
        "es-toolkit": "catalog:",
        "ky": "catalog:",
        "react": "catalog:",
        "react-dom": "catalog:",
        "react-intl": "catalog:",
        "react-router-dom": "catalog:"
    },
    "devDependencies": {
        "@navikt/fp-config-eslint": "workspace:*",
        "@navikt/fp-config-typescript": "workspace:*",
        "@navikt/fp-config-vite": "workspace:*",
        "@navikt/fp-utils-test": "workspace:*",
        "@storybook/react-vite": "catalog:",
        "@testing-library/dom": "catalog:",
        "@testing-library/jest-dom": "catalog:",
        "@testing-library/react": "catalog:",
        "@testing-library/user-event": "catalog:",
        "@types/express": "catalog:",
        "@types/jsdom": "28.0.3",
        "@types/morgan": "catalog:",
        "@types/node": "catalog:",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "dotenv": "catalog:",
        "eslint": "catalog:",
        "express": "catalog:",
        "http-proxy-middleware": "catalog:",
        "jsdom": "catalog:",
        "morgan": "catalog:",
        "mustache-express": "catalog:",
        "storybook": "catalog:",
        "tailwindcss": "catalog:",
        "ts-node": "catalog:",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vitest": "catalog:"
    },
    "packageManager": "pnpm@10.33.1",
    "msw": {
        "workerDirectory": [
            "mock-service-worker"
        ]
    }
}
