{
    "name": "foreldrepengeoversikt",
    "version": "1.0.0",
    "type": "module",
    "description": "NAV foreldrepengeoversikt",
    "repository": "https://github.com/navikt/foreldrepengeoversikt",
    "scripts": {
        "build": "vite build",
        "build:storybook": "storybook build -o .storybook-static-build",
        "test": "vitest --project=jsdom --watch=false",
        "test:browser": "vitest --project=browser",
        "eslint": "eslint \"./src/**/*.{js,ts,tsx}\"",
        "eslint:fix": "eslint --quiet --fix  \"./src/**/*.{js,ts,tsx}\"",
        "prettier:fix": "prettier --write src",
        "tsc": "tsc --noEmit",
        "tsc:watch": "tsc --noEmit --watch",
        "dev:vite": "vite",
        "dev:mock": "node --loader ts-node/esm ./mock-api/mock-api-server.ts",
        "dev:lokal": "node ./dev-server.cjs",
        "storybook": "storybook dev --quiet -p 7003"
    },
    "author": "NAV",
    "license": "MIT",
    "dependencies": {
        "@navikt/aksel-icons": "8.12.1",
        "@navikt/ds-css": "8.12.1",
        "@navikt/ds-react": "8.12.1",
        "@navikt/ds-tailwind": "8.12.1",
        "@navikt/fp-app-shell": "workspace:*",
        "@navikt/fp-constants": "workspace:*",
        "@navikt/fp-filopplaster": "workspace:*",
        "@navikt/fp-form-hooks": "workspace:*",
        "@navikt/fp-observability": "workspace:*",
        "@navikt/fp-types": "workspace:*",
        "@navikt/fp-ui": "workspace:*",
        "@navikt/fp-utils": "workspace:*",
        "@navikt/fp-uttaksplan": "workspace:*",
        "@navikt/fp-validation": "workspace:*",
        "@navikt/nav-dekoratoren-moduler": "4.2.2",
        "@sentry/vite-plugin": "5.3.0",
        "@tanstack/react-query": "5.101.0",
        "classnames": "2.5.1",
        "dayjs": "1.11.21",
        "jotai": "2.20.1",
        "ky": "2.0.2",
        "lodash": "4.18.1",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-intl": "10.1.13",
        "react-router-dom": "7.17.0"
    },
    "devDependencies": {
        "@navikt/fp-config-eslint": "workspace:*",
        "@navikt/fp-config-typescript": "workspace:*",
        "@navikt/fp-config-vite": "workspace:*",
        "@navikt/fp-utils-test": "workspace:*",
        "@storybook/react-vite": "10.4.4",
        "@testing-library/dom": "10.4.1",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/express": "5.0.6",
        "@types/jsdom": "28.0.3",
        "@types/lodash": "4.17.24",
        "@types/morgan": "1.9.10",
        "@types/node": "25.9.3",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "dotenv": "17.4.2",
        "eslint": "10.5.0",
        "express": "5.2.1",
        "http-proxy-middleware": "4.1.0",
        "jsdom": "29.1.1",
        "morgan": "1.11.0",
        "mustache-express": "1.3.2",
        "storybook": "10.4.4",
        "tailwindcss": "4.3.1",
        "ts-node": "^10.9.2",
        "typescript": "6.0.3",
        "vite": "8.0.16",
