{
    "extends": "@navikt/fp-config-typescript/tsconfig.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "paths": {
            "appData/*": ["./src/app-data/*"],
            "types/*": ["./src/types/*"],
            "utils/*": ["./src/utils/*"],
            "storybookData/*": ["./.storybook/storybook-data/*"]
        },
        "types": ["@testing-library/jest-dom", "vitest/globals", "vite/client"]
    },

    "include": ["src", "./@types", "mock-api", "vitest", "../../@types"],
    "exclude": ["node_modules", "build", "src/build", "dist", "**.js"]
}
