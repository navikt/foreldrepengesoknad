        "@navikt/fp-validation": "workspace:*",
        "react": "19.2.4",
        "react-dom": "19.2.4",
"react-hook-form": "7.72.0",
        "react-intl": "10.1.1"
    },
    "devDependencies": {
        "@formatjs/cli-lib": "8.5.0",
        "@navikt/ds-tailwind": "8.8.0",
        "@navikt/fp-config-eslint": "workspace:*",
