{
    "name": "@navikt/fp-app-shell",
    "description": "Felles oppsett av providers (Intl, Theme, ErrorBoundary, QueryClient, ds-react Provider) og bootstrap (Sentry, dayjs, countries) for alle fp-apper.",
    "main": "index.ts",
    "type": "module",
    "types": "index.ts",
    "scripts": {
        "eslint": "eslint \"./src/**/*.{js,ts,tsx}\"",
        "eslint:fix": "eslint --fix './src/**/*.{js,ts,tsx}' --color",
        "prettier:fix": "prettier --write src",
        "tsc": "tsc --noEmit",
        "tsc:watch": "tsc --noEmit --watch",
        "clean": "rm -rf ./dist ./node_modules ./.turbo"
    },
    "dependencies": {
        "@formatjs/intl-pluralrules": "6.3.10",
        "@navikt/ds-react": "catalog:",
        "@navikt/fp-observability": "workspace:*",
        "@navikt/fp-types": "workspace:*",
        "@navikt/fp-ui": "workspace:*",
        "@navikt/fp-utils": "workspace:*",
        "@navikt/nav-dekoratoren-moduler": "catalog:",
        "@tanstack/react-query": "catalog:",
        "@tanstack/react-query-devtools": "catalog:",
        "dayjs": "catalog:",
        "i18n-iso-countries": "catalog:",
        "ky": "catalog:",
        "react": "catalog:",
        "react-dom": "catalog:",
        "react-router-dom": "catalog:"
    },
    "devDependencies": {
        "@navikt/fp-config-eslint": "workspace:*",
        "@navikt/fp-config-typescript": "workspace:*",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "eslint": "catalog:",
        "typescript": "catalog:",
        "vite": "catalog:"
    },
    "packageManager": "pnpm@10.33.1"
}
