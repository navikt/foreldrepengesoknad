{
    "name": "@navikt/fp-steg-kvittering",
    "description": "Pakke som inneholder kvitteringssiden",
    "main": "index.ts",
    "type": "module",
    "types": "index.ts",
    "scripts": {
        "build:storybook": "storybook build -o .storybook-static-build",
        "test": "vitest --project=jsdom --watch=false",
        "test:browser": "vitest --project=browser",
        "eslint": "eslint \"./src/**/*.{js,ts,tsx}\"",
        "eslint:fix": "eslint --fix './src/**/*.{js,ts,tsx}' --color",
        "prettier:fix": "prettier --write src",
        "tsc": "tsc --noEmit",
        "tsc:watch": "tsc --noEmit --watch",
        "storybook": "storybook dev --quiet -p 7003"
    },
    "dependencies": {
        "@navikt/aksel-icons": "8.8.0",
        "@navikt/ds-css": "8.8.0",
        "@navikt/ds-react": "8.8.0",
        "@navikt/fp-types": "workspace:*",
        "@navikt/fp-ui": "workspace:*",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-intl": "10.1.1"
    },
    "devDependencies": {
        "@formatjs/cli-lib": "8.5.0",
        "@navikt/ds-tailwind": "8.8.0",
        "@navikt/fp-config-eslint": "workspace:*",
        "@navikt/fp-config-typescript": "workspace:*",
        "@navikt/fp-config-vite": "workspace:*",
        "@navikt/fp-utils-test": "workspace:*",
        "@storybook/addon-links": "10.3.4",
        "@storybook/react-vite": "10.3.4",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@types/react": "19.2.14",
        "eslint": "9.39.2",
        "fast-glob": "3.3.3",
        "jsdom": "29.0.1",
        "storybook": "10.3.4",
        "storybook-react-intl": "10.1.1",
        "tailwindcss": "4.2.2",
        "typescript": "6.0.2",
        "vite": "8.0.5",
        "vitest": "4.1.1"
    },
    "packageManager": "pnpm@10.28.0"
