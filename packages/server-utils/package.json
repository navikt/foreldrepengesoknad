{
    "name": "@navikt/fp-server-utils",
    "description": "Pakke som tilbyr generelle utils for serveroppsett",
    "main": "index.ts",
    "type": "module",
    "types": "index.ts",
    "scripts": {
        "eslint": "eslint \"./src/**/*.{js,ts,tsx}\"",
        "eslint:fix": "eslint --fix './src/**/*.{js,ts,tsx}' --color",
        "prettier:fix": "prettier --write src",
        "tsc": "tsc --noEmit",
        "tsc:watch": "tsc --noEmit --watch",
        "clean": "rm -rf ./dist ./node_modules ./.turbo"
    },
    "dependencies": {
        "@navikt/nav-dekoratoren-moduler": "catalog:",
        "@navikt/vite-mode": "0.16.1",
        "express": "catalog:",
        "morgan": "catalog:",
        "winston": "3.19.0"
    },
    "devDependencies": {
        "@navikt/fp-config-eslint": "workspace:*",
        "@navikt/fp-config-typescript": "workspace:*",
        "@types/express": "catalog:",
        "@types/morgan": "catalog:",
        "@types/node": "catalog:",
        "eslint": "catalog:",
        "typescript": "catalog:"
    }
}
