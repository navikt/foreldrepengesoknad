{
    "name": "@navikt/fp-ui",
    "description": "Pakke som tilbyr generelle komponenter som fil-opplaster",
    "main": "index.ts",
    "type": "module",
    "types": "index.ts",
    "scripts": {
        "build:storybook": "storybook build -o .storybook-static-build",
        "test": "vitest --project=jsdom --watch=false",
        "test:browser": "vitest --project=browser",
        "eslint": "eslint \"./src/**/*.{js,ts,tsx}\"",
        "eslint:fix": "eslint --fix './src/**/*.{js,ts,tsx}' --color",
        "prettier:fix": "prettier --write src",
        "tsc": "tsc --noEmit",
        "tsc:watch": "tsc --noEmit --watch",
        "storybook": "storybook dev --quiet -p 7003"
    },
    "dependencies": {
        "@navikt/aksel-icons": "catalog:",
        "@navikt/ds-css": "catalog:",
        "@navikt/ds-react": "catalog:",
        "@navikt/fp-constants": "workspace:*",
        "@navikt/fp-observability": "workspace:*",
        "@navikt/fp-types": "workspace:*",
        "@navikt/fp-utils": "workspace:*",
        "@radix-ui/react-slider": "^1.4.1",
        "dayjs": "catalog:",
        "detect-browser": "5.3.0",
        "react": "catalog:",
        "react-dom": "catalog:",
        "react-intl": "catalog:"
    },
    "devDependencies": {
        "@navikt/ds-tailwind": "catalog:",
        "@navikt/fp-config-eslint": "workspace:*",
        "@navikt/fp-config-typescript": "workspace:*",
        "@navikt/fp-config-vite": "workspace:*",
        "@navikt/fp-utils-test": "workspace:*",
        "@storybook/addon-links": "catalog:",
        "@storybook/react-vite": "catalog:",
        "@testing-library/jest-dom": "catalog:",
        "@testing-library/react": "catalog:",
        "@testing-library/user-event": "catalog:",
        "@types/react": "catalog:",
        "eslint": "catalog:",
        "jsdom": "catalog:",
        "storybook": "catalog:",
        "storybook-react-intl": "catalog:",
        "tailwindcss": "catalog:",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vitest": "catalog:"
    },
    "packageManager": "pnpm@10.33.1"
}
