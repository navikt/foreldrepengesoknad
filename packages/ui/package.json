{
    "name": "@navikt/fp-ui",
    "description": "Pakke som tilbyr generelle komponenter som fil-opplaster",
    "main": "index.ts",
    "type": "module",
    "types": "index.ts",
    "scripts": {
        "build:storybook": "storybook build -o .storybook-static-build",
        "test": "vitest --project=jsdom --watch=false",
        "test:browser": "vitest --project=browser",
        "eslint": "eslint \"./src/**/*.{js,ts,tsx}\"",
        "eslint:fix": "eslint --fix './src/**/*.{js,ts,tsx}' --color",
        "prettier:fix": "prettier --write src",
        "tsc": "tsc --noEmit",
        "tsc:watch": "tsc --noEmit --watch",
        "storybook": "storybook dev --quiet -p 7003"
    },
    "dependencies": {
        "@navikt/aksel-icons": "8.9.1",
        "@navikt/ds-css": "8.9.1",
        "@navikt/ds-react": "8.9.1",
        "@navikt/fp-constants": "workspace:*",
        "@navikt/fp-observability": "workspace:*",
        "@navikt/fp-types": "workspace:*",
        "@navikt/fp-utils": "workspace:*",
        "@radix-ui/react-slider": "^1.3.6",
        "dayjs": "1.11.20",
        "detect-browser": "5.3.0",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "react-intl": "10.1.2"
    },
    "devDependencies": {
        "@formatjs/cli-lib": "8.5.2",
        "@navikt/ds-tailwind": "8.9.1",
        "@navikt/fp-config-eslint": "workspace:*",
        "@navikt/fp-config-typescript": "workspace:*",
        "@navikt/fp-config-vite": "workspace:*",
        "@navikt/fp-utils-test": "workspace:*",
        "@storybook/addon-links": "10.3.5",
        "@storybook/react-vite": "10.3.5",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/react": "19.2.14",
        "eslint": "9.39.2",
        "fast-glob": "3.3.3",
        "jsdom": "29.0.2",
        "storybook": "10.3.5",
        "storybook-react-intl": "10.1.1",
        "tailwindcss": "4.2.2",
        "typescript": "6.0.2",
        "vite": "8.0.8",
        "vitest": "4.1.4"
    },
    "packageManager": "pnpm@10.28.0"
}
