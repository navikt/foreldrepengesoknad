        "@testing-library/user-event": "14.6.1",
        "@types/react": "19.2.14",
        "eslint": "9.39.2",
        "fast-glob": "3.3.3",
        "playwright": "1.58.2",
        "storybook": "10.2.19",
        "storybook-react-intl": "10.1.1",
