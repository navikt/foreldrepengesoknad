{
    "name": "fp-selvbetjening",
    "private": true,
    "scripts": {
        "build": "turbo build",
        "build:storybook": "turbo run build:storybook --force && pnpm run storybook-create-deploy-folder",
        "test": "turbo test",
        "test:browser": "turbo run test:browser",
        "ci": "turbo run build test",
        "eslint": "turbo run eslint",
        "eslint:fix": "turbo run eslint:fix",
        "prettier:fix": "turbo run prettier:fix",
        "tsc": "turbo run tsc",
        "tsc:watch": "tsc --noEmit --watch",
        "knip": "knip",
        "storybook-create-deploy-folder": "node scripts/create-storybook-index.mjs",
        "generate:local": "pnpm --filter @navikt/fp-types run generate:local",
        "generate": "pnpm --filter @navikt/fp-types run generate",
        "clean": "pnpm -r run clean && rm -rf ./node_modules ./.turbo"
    },
    "dependencies": {
        "lint-staged": "17.0.8",
        "turbo": "2.9.18"
    },
    "devDependencies": {
        "@trivago/prettier-plugin-sort-imports": "6.0.2",
        "@types/node": "catalog:",
        "knip": "6.17.0",
        "msw": "2.14.6",
        "msw-storybook-addon": "2.0.7",
        "prettier": "3.8.4",
        "typescript": "catalog:"
    },
    "lint-staged": {
        "apps/**/*.{ts,tsx,js,jsx, css}": "prettier --write",
        "packages/**/*.{ts,tsx,js,jsx, css}": "prettier --write"
    },
    "packageManager": "pnpm@11.9.0",
    "msw": {
        "workerDirectory": [
            "./scripts/mock-service-worker"
        ]
    }
}
