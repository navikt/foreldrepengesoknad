{
    "name": "fp-selvbetjening",
    "private": true,
    "scripts": {
        "build": "turbo build",
        "build:storybook": "turbo run build:storybook && pnpm run storybook-create-deploy-folder",
        "test": "turbo test",
        "test:browser": "turbo run test:browser",
        "eslint": "turbo run eslint",
        "eslint:fix": "turbo run eslint:fix",
        "prettier:fix": "turbo run prettier:fix",
        "tsc": "turbo run tsc",
        "dev:vite": "pnpm --filter foreldrepengesoknad run dev:vite",
        "dev:mock": "pnpm --filter foreldrepengesoknad run dev:mock",
        "dev:lokal": "pnpm --filter foreldrepengesoknad run dev:lokal",
        "dev": "turbo dev",
        "knip": "knip",
        "lint": "turbo lint",
        "fp": "pnpm --filter foreldrepengesoknad run dev",
        "fp-prod": "pnpm --filter foreldrepengesoknad run start",
        "storybook-common": "pnpm --filter @navikt/fp-common run storybook",
        "storybook-create-deploy-folder": "node scripts/create-storybook-index.js",
        "prepare": "husky install",
        "generate:local": "pnpm --filter @navikt/fp-types run generate:local",
        "generate": "pnpm --filter @navikt/fp-types run generate"
    },
    "dependencies": {
        "gh-pages": "6.3.0",
        "glob": "13.0.0",
        "husky": "9.1.7",
        "lint-staged": "16.2.7",
        "shelljs": "0.10.0",
        "turbo": "2.8.2"
    },
    "devDependencies": {
        "@trivago/prettier-plugin-sort-imports": "6.0.2",
        "knip": "5.83.0",
        "msw": "2.12.7",
        "msw-storybook-addon": "2.0.6",
        "prettier": "3.8.1",
        "prettier-plugin-tailwindcss": "0.7.2"
    },
    "lint-staged": {
        "apps/**/*.{ts,tsx,js,jsx, css}": "prettier --write",
        "packages/**/*.{ts,tsx,js,jsx, css}": "prettier --write"
    },
    "packageManager": "pnpm@10.28.0",
    "msw": {
        "workerDirectory": [
            "./scripts/mock-service-worker"
        ]
    }
}
