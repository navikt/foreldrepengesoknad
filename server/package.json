{
    "name": "@navikt/server",
    "version": "1.0.0",
    "license": "MIT",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "esbuild ./src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.js",
        "test": "vitest run",
        "tsc:watch": "tsc --noEmit --watch",
        "start": "node ./server.js",
        "clean": "rm -rf ./dist ./node_modules ./.turbo"
    },
    "dependencies": {
        "@navikt/fp-server-utils": "workspace:*",
        "@navikt/oasis": "4.1.4",
        "express": "catalog:",
        "http-proxy-middleware": "catalog:"
    },
    "devDependencies": {
        "@navikt/fp-config-typescript": "workspace:*",
        "@types/express": "catalog:",
        "@types/node": "catalog:",
        "@types/supertest": "7.2.1",
        "esbuild": "catalog:",
        "supertest": "7.2.2",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
