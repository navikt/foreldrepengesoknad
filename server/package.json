    },
    "devDependencies": {
        "@navikt/fp-config-typescript": "workspace:*",
        "@types/express": "5.0.6",
        "@types/node": "24.10.1",
        "@types/supertest": "7.2.0",
        "esbuild": "0.28.0",
        "supertest": "7.2.2",
        "typescript": "6.0.3",
        "vitest": "4.1.6"
    },
    "packageManager": "pnpm@10.33.1"
}
