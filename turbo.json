{
    "$schema": "https://v2-10-0.turborepo.dev/schema.json",
    "globalPassThroughEnv": [
        "NODE_AUTH_TOKEN",
        "PACKAGES_AUTH_TOKEN",
        "SENTRY_AUTH_TOKEN",
        "VITE_SENTRY_RELEASE"
    ],
    "globalDependencies": [
        "turbo.json",
        "pnpm-lock.yaml",
        "knip.ts",
        "Dockerfile",
        ".prettierrc",
        "packages/config-eslint/eslint.config.mjs",
        "packages/config-typescript/tsconfig.json",
        "packages/config-vite/vite.config.mjs"
    ],
    "tasks": {
        "dev": {
            "cache": false,
            "persistent": true
        },
        "generate": {
            "cache": false
        },
        "generate:local": {
            "cache": false
        },
        "tsc": {
            "outputs": []
        },
        "eslint": {
            "outputs": []
        },
        "eslint:fix": {
            "outputs": []
        },
        "prettier:fix": {
            "outputs": []
        },
        "test": {
            "dependsOn": ["build", "^test"],
            "outputs": []
        },
        "test:browser": {
            "dependsOn": ["build", "^test:browser"],
            "outputs": []
        },
        "build:storybook": {
            "outputs": [".storybook-static-build/**"]
        },
        "build": {
            "dependsOn": ["^build", "tsc"],
            "outputs": ["dist/**", "lib/**"]
        }
    },
    "globalEnv": [
        "APPRES_CMS_URL",
        "APP_VERSION",
        "FEATURE_TEST_1JULI2024_REGLER",
        "LOG_VALIDATION",
        "INNSYN",
        "NODE_ENV",
        "ENV",
        "PORT"
    ]
}
